# Copy to .env and adjust:  cp .env.example .env
# Used by docker compose (optional env_file) and local runs when cwd loads .env.

# ---------- AI core — app ----------
INTERNAL_TOKEN=dev-internal-token
APP_NAME=ai-assistant-core
# Comma-separated origins for FastAPI CORS (leave empty for no CORS middleware)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------- Audit / any SQL database (SQLAlchemy async URL) ----------
# PostgreSQL: postgresql+asyncpg://user:pass@host:5432/dbname
# SQLite file: sqlite+aiosqlite:///./local_audit.db  (pip install aiosqlite)
# MySQL: mysql+aiomysql://user:pass@host:3306/dbname  (pip install aiomysql)
AUDIT_BACKEND=auto
DATABASE_URL=

# Aliases also work: SQLALCHEMY_DATABASE_URI, AUDIT_DATABASE_URL

# ---------- Ingest (UI uploads) ----------
# INGEST_MAX_UPLOAD_BYTES=10485760

# ---------- Vector store ----------
VECTOR_BACKEND=auto
QDRANT_URL=http://localhost:6333
VECTOR_COLLECTION=assistant_chunks
QDRANT_DISTANCE=cosine
SEED_VECTOR_COLLECTION_ON_STARTUP=false
VECTOR_SEARCH_LIMIT=12

# ---------- Embeddings ----------
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# OpenAI-compatible /v1 (Ollama: http://localhost:11434/v1, vLLM, etc.)
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_REQUEST_TIMEOUT_SECONDS=120

# ---------- LLM (OpenAI-compatible /v1/chat/completions) ----------
LLM_BACKEND=auto
# Local runs: Ollama on the host (Compose sets these on ai-core automatically)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
# Or set LLM_BASE_URL explicitly (include /v1):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=
# OLLAMA_HOST=localhost:11434
# Docker Compose: Ollama runs as service `ollama`; pull a model once, e.g.
#   docker compose exec ollama ollama pull llama3.2:3b
# Compose defaults: OLLAMA_BASE_URL=http://ollama:11434, LLM_MODEL=llama3.2:3b
LLM_REQUEST_TIMEOUT_SECONDS=120

# Aliases: OPENAI_BASE_URL, VLLM_BASE_URL, LM_STUDIO_BASE_URL → LLM_BASE_URL

# ---------- OpenTelemetry (optional) ----------
# OTEL_SDK_DISABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=ai-assistant-core

# ---------- BFF (when running Spring Boot locally; compose sets these) ----------
# SPRING_PROFILES_ACTIVE=dev
# BFF_AI_CORE_BASE_URL=http://localhost:8081
# BFF_AI_CORE_INTERNAL_TOKEN=dev-internal-token
# BFF_AI_CORE_TIMEOUT_SECONDS=330
# BFF_FORWARD_AUTH=false
# JWT_ISSUER_URI=http://localhost:8180/realms/ai-assistant
